# Local development defaults to .data/scans.json when no Postgres URL is present.
# Set DATABASE_URL for production Postgres persistence.
# Vercel/Neon-style POSTGRES_URL aliases are also accepted by the runtime and db:migrate.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Set to true only when the managed Postgres provider requires TLS verification.
DATABASE_SSL=false

# Optional local file-store path for development.
SCAN_STORE_PATH=.data/scans.json
ORDER_STORE_PATH=.data/orders.json
MONITORING_STORE_PATH=.data/monitoring.json
BETA_SCAN_SETTINGS_STORE_PATH=.data/beta-scan-settings.json
BETA_SCAN_USAGE_STORE_PATH=.data/beta-scan-usage.json
BETA_SCAN_LOAD_STORE_PATH=.data/beta-scan-load.json
ADMIN_AUDIT_LOG_STORE_PATH=.data/admin-audit-log.json

# Local developer testing. Defaults to admin/admin on localhost only.
ENABLE_DEV_ADMIN=
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=
DEV_ADMIN_SECRET=
REPORT_TOKEN_SECRET=
FIRST_FREE_FINGERPRINT_SECRET=

# Required in production for /api/cron/prune.
# Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
MONITORING_CRON_LIMIT=3

# Scan provider:
# - maigret: require real Maigret scan results and fail if unavailable
# - mock: deterministic local scanner only
SCAN_PROVIDER=maigret
MAIGRET_BIN=maigret
MAIGRET_TOP_SITES_QUICK=35
MAIGRET_TOP_SITES_DEEP=150
MAIGRET_DEEP_ALL=false
MAIGRET_SITE_TIMEOUT_SECONDS=6
MAIGRET_RETRIES=1
MAIGRET_PROCESS_TIMEOUT_MS=58000
MAIGRET_MAX_CONNECTIONS=20
MAIGRET_PRIORITY_SITES=Instagram,Twitter,Threads,TikTok,YouTube,Facebook,LinkedIn,Naver,GitHub,GitHubGist,Reddit
MAIGRET_PRIORITY_RESCAN=true
MAIGRET_PRIORITY_SITE_TIMEOUT_SECONDS=14
MAIGRET_PRIORITY_MAX_CONNECTIONS=6
MAIGRET_PRIORITY_RETRIES=1
MAIGRET_CRITICAL_SITES=Twitter,Instagram,Threads
MAIGRET_CRITICAL_RESCAN=adaptive
MAIGRET_CRITICAL_SITE_TIMEOUT_SECONDS=22
MAIGRET_CRITICAL_MAX_CONNECTIONS=3
MAIGRET_CRITICAL_RETRIES=2
MAIGRET_BOOST_TAGS=kr:30,social:35,photo:16,video:16,blog:20,coding:20,music:10,design:10,streaming:8,messaging:8
MAIGRET_EXCLUDED_SITES=Geeksfor Geeks
MAIGRET_EXCLUDED_TAGS=porn
MAIGRET_SITE_CAP_QUICK=155
MAIGRET_SITE_CAP_DEEP=260
MAIGRET_EXTRACT_EXTENDED=true
SCAN_RESULT_METADATA_ENABLED=true
SCAN_RESULT_METADATA_LIMIT=3
SCAN_RESULT_METADATA_TIMEOUT_MS=1200
SCAN_RESULT_METADATA_MAX_BYTES=65536
MAIGRET_API_SECRET=
# Vercel beta without Postgres: include full results/source HTML in the first scan response so the client can render details.
# Keep false/empty when a Postgres URL is configured for durable paid reports.
INLINE_SCAN_ARTIFACTS=false

# Beta search controls. Admins can adjust these at /admin.
BETA_PUBLIC_SCAN_ENABLED=true
BETA_FREE_SCAN_LIMIT=1
BETA_FREE_SCAN_WINDOW_HOURS=24
# Production default: one free search per person for the lifetime of the account/device quota.
BETA_FREE_SCAN_LIFETIME=true
# Keep referral bonuses disabled while the paid funnel is active.
BETA_REFERRAL_TICKETS_ENABLED=false
BETA_MAX_CONCURRENT_SCANS=6
BETA_SCAN_BUSY_RETRY_AFTER_SECONDS=30
BETA_SCAN_LEASE_TTL_SECONDS=90

# Payment provider:
# - mock: local checkout for smoke tests
# - toss: Toss Payments hosted payment window and confirm API
# - polar: Polar hosted checkout session and signed webhook
# - portone: PortOne V2 browser checkout and REST payment verification
# - inicis: KG Inicis standard payment window and approval API
PAYMENT_PROVIDER=mock
ENABLE_MOCK_PAYMENTS=false
# Temporary hosted-payment-link override. When set, checkout buttons open the Groble link
# instead of the built-in Toss/Polar/PortOne/Inicis flow, while keeping the old provider code in place.
GROBLE_PAYMENT_URL=
GROBLE_DETAILED_REPORT_URL=
GROBLE_MONTHLY_MONITORING_URL=
# Beta default: keep one-time free detailed reports enabled until checkout is ready.
# Set true after payment checkout is live to require checkout for detailed web reports.
WEB_DETAILED_REPORT_PAYWALL_ENABLED=false
# Set true after the monthly monitoring checkout product is live.
MONITORING_PAYWALL_ENABLED=false
SITE_URL=http://localhost:3000
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_SECURITY_KEY=
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_MONTHLY_MONITORING_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=

NEXT_PUBLIC_PORTONE_STORE_ID=store-0a47c3c4-3b2c-4037-a77b-4fd1ee0b575f
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=
INICIS_MID=
INICIS_SIGN_KEY=
INICIS_BUYER_NAME=
INICIS_BUYER_TEL=
INICIS_BUYER_EMAIL=
# Optional. Set to sandbox only when using Polar sandbox products/tokens.
POLAR_SERVER=production
PRODUCTION_BASE_URL=
STORE_PRODUCTION_ORIGIN=
STORE_SUPPORT_EMAIL=support@YOUR_DOMAIN

# Apps in Toss mini-app registration and review.
TOSS_CONSOLE_API_KEY=
TOSS_CONSOLE_APP_ID=
TOSS_MINI_APP_NAME=
TOSS_ALLOWED_ORIGINS=https://YOUR_TOSS_APP_NAME.apps.tossmini.com,https://YOUR_TOSS_APP_NAME.private-apps.tossmini.com
TOSS_REVIEW_TEST_USERNAME=khstar104
TOSS_REVIEW_SCENARIO=Enter the review username, acknowledge legitimate purpose, run the free scan, then open the detailed report checkout.

# First-party launch monitoring. Client telemetry records page views, Core Web Vitals,
# and client-side errors to structured server logs without cookies or raw search input.
TELEMETRY_DISABLED=false
NEXT_PUBLIC_TELEMETRY_DISABLED=false
RELEASE_VERSION=local
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_PROVIDER=generic
ALERT_WEBHOOK_TIMEOUT_MS=1500
ALERT_RUNBOOK_URL=https://YOUR_PRODUCTION_DOMAIN/runbooks/launch

# Native App Store / Play Store wrapper build configuration.
# Must be set to the production HTTPS origin before running mobile:configure for release builds.
MOBILE_APP_ORIGIN=https://YOUR_PRODUCTION_DOMAIN
MOBILE_SUPPORT_URL=https://YOUR_PRODUCTION_DOMAIN/responsible-use
MOBILE_PRIVACY_URL=https://YOUR_PRODUCTION_DOMAIN/privacy
MOBILE_TERMS_URL=https://YOUR_PRODUCTION_DOMAIN/terms
MOBILE_PAYMENTS_ENABLED=false

# Native App Store / Google Play receipt verification.
# Required before enabling MOBILE_PAYMENTS_ENABLED=true in native app builds.
# The native layer must also inject window.IDD_NATIVE_BILLING for StoreKit / Play Billing.
APPLE_BUNDLE_ID=com.iddoppelganger.app
APPLE_DETAILED_REPORT_PRODUCT_ID=detailed_report
APPLE_ENVIRONMENT=sandbox
APPLE_KEY_ID=
APPLE_ISSUER_ID=
# PEM contents; use escaped newlines in environment managers that require single-line values.
APPLE_PRIVATE_KEY=
# Optional but recommended for local JWS verification of signed App Store transaction data.
APPLE_REQUIRE_JWS_VERIFICATION=false
APPLE_ROOT_CERTIFICATES_BASE64=
APPLE_APP_APPLE_ID=

GOOGLE_PLAY_PACKAGE_NAME=com.iddoppelganger.app
GOOGLE_PLAY_DETAILED_REPORT_PRODUCT_ID=detailed_report
# JSON service account credentials with Android Publisher API access.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Android release AAB upload signing. Keep the real keystore out of git.
# Use BASE64 for CI/GitHub Actions, or set GOOGLE_PLAY_UPLOAD_KEYSTORE_PATH locally.
GOOGLE_PLAY_UPLOAD_KEYSTORE_BASE64=
GOOGLE_PLAY_UPLOAD_KEYSTORE_PATH=
GOOGLE_PLAY_UPLOAD_KEYSTORE_PASSWORD=
GOOGLE_PLAY_UPLOAD_KEY_ALIAS=
GOOGLE_PLAY_UPLOAD_KEY_PASSWORD=

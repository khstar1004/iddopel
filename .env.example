# Local development defaults to .data/scans.json when DATABASE_URL is absent.
# Set DATABASE_URL for production Postgres persistence.
DATABASE_URL=

# Set to true only when the managed Postgres provider requires TLS verification.
DATABASE_SSL=false

# Optional local file-store path for development.
SCAN_STORE_PATH=.data/scans.json
ORDER_STORE_PATH=.data/orders.json
MONITORING_STORE_PATH=.data/monitoring.json

# Local developer testing. Defaults to admin/admin on localhost only.
ENABLE_DEV_ADMIN=
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=
DEV_ADMIN_SECRET=
REPORT_TOKEN_SECRET=

# Required in production for /api/cron/prune.
# Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
MONITORING_CRON_LIMIT=3

# Scan provider:
# - maigret: require real Maigret scan results and fail if unavailable
# - mock: deterministic local scanner only
SCAN_PROVIDER=maigret
MAIGRET_BIN=maigret
MAIGRET_TOP_SITES_QUICK=100
MAIGRET_TOP_SITES_DEEP=500
MAIGRET_DEEP_ALL=false
MAIGRET_SITE_TIMEOUT_SECONDS=12
MAIGRET_PROCESS_TIMEOUT_MS=120000
MAIGRET_API_SECRET=

# Payment provider:
# - mock: local checkout for smoke tests
# - toss: Toss Payments hosted payment window and confirm API
PAYMENT_PROVIDER=mock
ENABLE_MOCK_PAYMENTS=false
# Beta default: keep one-time free detailed reports enabled until Toss PG is ready.
# Set true after payment checkout is live to require checkout for detailed web reports.
WEB_DETAILED_REPORT_PAYWALL_ENABLED=false
SITE_URL=http://localhost:3000
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_SECURITY_KEY=
PRODUCTION_BASE_URL=
STORE_PRODUCTION_ORIGIN=
STORE_SUPPORT_EMAIL=support@YOUR_DOMAIN

# Apps in Toss mini-app registration and review.
TOSS_CONSOLE_API_KEY=
TOSS_CONSOLE_APP_ID=
TOSS_MINI_APP_NAME=
TOSS_ALLOWED_ORIGINS=https://YOUR_TOSS_APP_NAME.apps.tossmini.com,https://YOUR_TOSS_APP_NAME.private-apps.tossmini.com
TOSS_REVIEW_TEST_USERNAME=khstar104
TOSS_REVIEW_SCENARIO=Enter the review username, acknowledge legitimate purpose, run the free scan, then open the detailed report checkout.

# First-party launch monitoring. Client telemetry records page views, Core Web Vitals,
# and client-side errors to structured server logs without cookies or raw search input.
TELEMETRY_DISABLED=false
NEXT_PUBLIC_TELEMETRY_DISABLED=false
RELEASE_VERSION=local
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_PROVIDER=generic
ALERT_WEBHOOK_TIMEOUT_MS=1500
ALERT_RUNBOOK_URL=https://YOUR_PRODUCTION_DOMAIN/runbooks/launch

# Native App Store / Play Store wrapper build configuration.
# Must be set to the production HTTPS origin before running mobile:configure for release builds.
MOBILE_APP_ORIGIN=https://YOUR_PRODUCTION_DOMAIN
MOBILE_SUPPORT_URL=https://YOUR_PRODUCTION_DOMAIN/responsible-use
MOBILE_PRIVACY_URL=https://YOUR_PRODUCTION_DOMAIN/privacy
MOBILE_TERMS_URL=https://YOUR_PRODUCTION_DOMAIN/terms
MOBILE_PAYMENTS_ENABLED=false

# Native App Store / Google Play receipt verification.
# Required before enabling MOBILE_PAYMENTS_ENABLED=true in native app builds.
# The native layer must also inject window.IDD_NATIVE_BILLING for StoreKit / Play Billing.
APPLE_BUNDLE_ID=com.iddoppelganger.app
APPLE_DETAILED_REPORT_PRODUCT_ID=detailed_report
APPLE_ENVIRONMENT=sandbox
APPLE_KEY_ID=
APPLE_ISSUER_ID=
# PEM contents; use escaped newlines in environment managers that require single-line values.
APPLE_PRIVATE_KEY=
# Optional but recommended for local JWS verification of signed App Store transaction data.
APPLE_REQUIRE_JWS_VERIFICATION=false
APPLE_ROOT_CERTIFICATES_BASE64=
APPLE_APP_APPLE_ID=

GOOGLE_PLAY_PACKAGE_NAME=com.iddoppelganger.app
GOOGLE_PLAY_DETAILED_REPORT_PRODUCT_ID=detailed_report
# JSON service account credentials with Android Publisher API access.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

{
  "env": {
    "SCAN_PROVIDER": "maigret",
    "SCAN_STORE_PATH": "/tmp/id-doppelganger-scans.json",
    "ORDER_STORE_PATH": "/tmp/id-doppelganger-orders.json",
    "MONITORING_STORE_PATH": "/tmp/id-doppelganger-monitoring.json",
    "BETA_SCAN_SETTINGS_STORE_PATH": "/tmp/id-doppelganger-beta-scan-settings.json",
    "BETA_SCAN_USAGE_STORE_PATH": "/tmp/id-doppelganger-beta-scan-usage.json",
    "BETA_SCAN_LOAD_STORE_PATH": "/tmp/id-doppelganger-beta-scan-load.json",
    "ADMIN_AUDIT_LOG_STORE_PATH": "/tmp/id-doppelganger-admin-audit-log.json",
    "BETA_PUBLIC_SCAN_ENABLED": "true",
    "BETA_FREE_SCAN_LIMIT": "1",
    "BETA_FREE_SCAN_WINDOW_HOURS": "24",
    "BETA_MAX_CONCURRENT_SCANS": "6",
    "BETA_SCAN_BUSY_RETRY_AFTER_SECONDS": "30",
    "BETA_SCAN_LEASE_TTL_SECONDS": "90",
    "MONITORING_CRON_LIMIT": "3",
    "ENABLE_DEV_ADMIN": "true",
    "MAIGRET_TOP_SITES_QUICK": "35",
    "MAIGRET_TOP_SITES_DEEP": "150",
    "MAIGRET_SITE_TIMEOUT_SECONDS": "10",
    "MAIGRET_RETRIES": "1",
    "MAIGRET_PROCESS_TIMEOUT_MS": "55000",
    "MAIGRET_MAX_CONNECTIONS": "10",
    "MAIGRET_PRIORITY_SITES": "Instagram,Twitter,Threads,TikTok,YouTube,Facebook,LinkedIn,Naver,GitHub,GitHubGist,Reddit",
    "MAIGRET_EXTRACT_EXTENDED": "false",
    "INLINE_SCAN_ARTIFACTS": "false",
    "SITE_URL": "https://iddopel.vercel.app",
    "ENABLE_MOCK_PAYMENTS": "false"
  },
  "functions": {
    "api/maigret_scan.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/prune",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 1 * * *"
    }
  ]
}
